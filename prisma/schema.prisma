// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  clerkId       String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  links            Link[]
  createdAt        DateTime @default(now())
  subscribed       Boolean  @default(true)
  source           String?
  defaultWorkspace String?

  @@index(source)
  @@index(defaultWorkspace)
}

model Link {
  id         String    @id @default(cuid())
  domain     String
  key        String
  url        String
  expiresAt  DateTime?
  expiredUrl String?
  password   String?
  externalId String?

  proxy       Boolean @default(false)
  title       String?
  description String?
  image       String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  publicStats Boolean   @default(false)
  clicks      Int       @default(0)
  lastClicked DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tags LinkTag[]
}

model LinkTag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("blue")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  Link      Link?    @relation(fields: [linkId], references: [id])
  linkId    String?

  @@unique([name, projectId])
  @@index(projectId)
}

enum PortalRole {
  USER
  MANAGER
  ANALYST
  ADMIN
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

model PortalUser {
  id         String     @id @default(cuid())
  fullName   String
  email      String     @unique
  role       PortalRole @default(USER)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Broker {
  id           String          @id @default(cuid())
  name         String
  description  String
  ctaLabel     String          @default("Open Account")
  ctaUrl       String
  logoUrl      String?
  highlighted  Boolean         @default(false)
  isActive     Boolean         @default(true)
  orderIndex   Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  benefits     BrokerBenefit[]
}

model BrokerBenefit {
  id        String   @id @default(cuid())
  brokerId  String
  text      String
  createdAt DateTime @default(now())
  broker    Broker   @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId])
}

model Enquiry {
  id         String        @id @default(cuid())
  firstName  String
  lastName   String
  email      String
  phone      String        @default("")
  subject    String
  message    String
  sourceIpHash String?
  userAgent  String?
  status     EnquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([createdAt])
  @@index([email, createdAt])
  @@index([sourceIpHash, createdAt])
}

model SiteVisit {
  id          String   @id @default(cuid())
  path        String
  deviceType  String
  country     String?
  userAgent   String?
  ipHash      String?
  visitSession String?
  cookieEnabled Boolean?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([deviceType])
  @@index([country])
  @@index([path, createdAt])
  @@index([visitSession, createdAt])
}

model AdminLoginEvent {
  id          String   @id @default(cuid())
  email       String
  role        String?
  ipAddress   String?
  ipHash      String?
  country     String?
  deviceType  String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([email, createdAt])
}
